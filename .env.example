# Telegram Bot Token from @BotFather.
# Set as a Worker secret via: wrangler secret put TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz

# Numeric Telegram user ID of the SINGLE account allowed to use the bot.
# Anyone else is silently dropped. Find yours via @userinfobot.
# Set as a Worker secret via: wrangler secret put ALLOWED_TELEGRAM_USER_ID
ALLOWED_TELEGRAM_USER_ID=000000000

# GitHub classic PAT with `repo` + `workflow` scopes.
# Used by the Cloudflare Worker to fire `repository_dispatch` at the Actions workflow.
# Set as a Worker secret via: wrangler secret put GH_PAT_TOKEN
GH_PAT_TOKEN=[REDACTED:github_token]

# Owner + name of the public repo that hosts the workflow.
# Set as Worker secrets via: wrangler secret put GITHUB_REPO_OWNER / GITHUB_REPO_NAME
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=telegram-depth-anything-bot
