# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIjKlMnOpQrStUvWxYz

# Numeric Telegram user ID of the SINGLE account allowed to use the bot.
# Anyone else is silently dropped. Find yours via @userinfobot.
ALLOWED_TELEGRAM_USER_ID=000000000

# GitHub classic PAT with `repo` + `workflow` scopes.
# Used by Vercel to fire `repository_dispatch` at the Actions workflow.
GH_PAT_TOKEN=[REDACTED:github_token]

# Owner + name of the public repo that hosts the workflow.
GITHUB_REPO_OWNER=your-github-username
GITHUB_REPO_NAME=telegram-depth-anything-bot
